{
    "name": "career-craft-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
        "dev": "npm start",
        "start:frontend": "npm run dev --workspace=frontend",
        "start:backend": "npm run dev --workspace=backend",
        "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "html2canvas": "^1.4.1",
        "jspdf": "^4.0.0"
    }
}
