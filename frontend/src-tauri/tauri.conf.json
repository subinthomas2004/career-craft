{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Career Craft",
  "version": "0.1.0",
  "identifier": "com.careercraft.app",
  "build": {
    "frontendDist": "https://career-craft-frontend-nu.vercel.app",
    "devUrl": "https://career-craft-frontend-nu.vercel.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Career Craft",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
